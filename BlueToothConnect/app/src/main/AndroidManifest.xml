<?xml version="1.0" encoding="utf-8"?>
<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <Button
            android:id="@+id/scan_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Scan Devices" />

        <com.github.mikephil.charting.charts.LineChart
            android:id="@+id/wave_chart"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:layout_marginTop="16dp" />

        <TextView
            android:id="@+id/thd_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="THD: --"
            android:textSize="18sp" />

        <TextView
            android:id="@+id/freq_value"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Frequency: -- Hz"
            android:textSize="18sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Harmonics (Normalized)"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/harmonic1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="H1: --" />

        <TextView
            android:id="@+id/harmonic2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="H2: --" />

        <TextView
            android:id="@+id/harmonic3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="H3: --" />

        <TextView
            android:id="@+id/harmonic4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="H4: --" />

        <TextView
            android:id="@+id/harmonic5"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="H5: --" />
    </LinearLayout>
</ScrollView>

<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.BlueToothConnect"
        tools:targetApi="31">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:label="@string/app_name"
            android:theme="@style/Theme.BlueToothConnect">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>